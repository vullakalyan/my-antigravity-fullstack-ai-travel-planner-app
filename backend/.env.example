# Environment Variables — AI Travel Planner Backend
# Copy this file to .env and fill in your values

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://localhost:27017/ai-travel-planner

# JWT signing secret — use a long, random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Anthropic Claude API Key
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Server port
PORT=5000

# Allowed frontend origin for CORS (no trailing slash)
CORS_ORIGIN=http://localhost:3000

# Node environment: development | production | test
NODE_ENV=development
